{
  "name": "gst-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "node apps/api/src/index.js",
    "dev:worker": "node apps/worker/src/index.js",
    "dev:admin": "node apps/admin/src/index.js",
    "source-engine": "node packages/source-engine/src/index.js",
    "db:init": "psql -U postgres -d gst_platform -f database/bootstrap.sql && psql -U postgres -d gst_platform -f database/schema.sql && psql -U postgres -d gst_platform -f database/seed.sql",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "deploy": "./deploy.sh",
    "backup": "./backup.sh",
    "start": "docker-compose up -d"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pdf2json": "^4.0.3",
    "pg": "^8.22.0"
  }
}
